{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "environments/environment.dev.ts",
        "outDir": "dist/environments",
        "watchAssets": true
      },
      {
        "include": "environments/environment.pre.ts",
        "outDir": "dist/environments",
        "watchAssets": true
      },
      {
        "include": "environments/environment.prod.ts",
        "outDir": "dist/environments",
        "watchAssets": true
      }
    ]
  }
}
